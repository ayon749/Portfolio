# Copy this file to .env.local and fill in your Supabase project values.
# Find them in Supabase Dashboard -> Project Settings -> API.
# These are PUBLIC (anon) keys — safe to expose in a static site because
# Row Level Security on the database controls who can write.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Only needed for GitHub Pages PROJECT sites (user.github.io/repo-name).
# The deploy workflow sets this automatically. Leave empty for local dev
# and for user/org pages (user.github.io).
# NEXT_PUBLIC_BASE_PATH=/portfolio
